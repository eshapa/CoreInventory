# Environment Variables — CoreInventory Backend (.env.example)
# Copy this file to .env and fill in your actual values.
NODE_ENV=development
PORT=5000

# ─── TiDB / MySQL ─────────────────────────────
TIDB_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your_tidb_username
TIDB_PASSWORD=your_tidb_password
TIDB_DATABASE=coreinventory
# Set to "true" to enable SSL (required for TiDB Cloud)
TIDB_SSL=true

# ─── JWT ──────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_REFRESH_EXPIRE=7d

# ─── Nodemailer / SMTP ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=your_email@gmail.com
APP_NAME=CoreInventory

# ─── Client ───────────────────────────────────
CLIENT_URL=http://localhost:5173
